---
import Layout from "../layouts/Layout.astro"
import {LockKeyhole,LockKeyholeOpen} from "@lucide/astro"
---
<Layout title="StegLLM" alert>
  <div class="shadow p-4">
      <button class="btn btn-soft btn-warning" id="generateKeyPair"></button>
  </div>
  <div class="flex flex-col p-4 mx-6 lg:mx-14 2xl:mx-42">
    <div class="flex flex-col md:flex-row gap-6 lg:gap-12">
      <div class="py-6 flex flex-col gap-6 flex-1">
        <textarea class="textarea textarea-info w-full h-136 bg-base-200" id="secret"></textarea>
        <fieldset class="fieldset">
          <legend class="fieldset-legend" id="publicKeyTitle"></legend>
          <div class="flex flex-row gap-6 items-center">
            <input type="file" class="file-input file-input-success" id="publicKey" aria-labelledby="publicKeyTitle"/>
            <label class="label tooltip" id="stopTip">
                <input type="checkbox" class="toggle toggle-info" id="insertion"/>
                <span id="insertionText"></span>
            </label>
          </div>
        </fieldset>
      </div>
      <div class="flex flex-col items-center justify-center gap-8">
        <button class="btn btn-primary btn-circle btn-xl" id="hide"><LockKeyhole/></button>
        <button class="btn btn-secondary btn-circle btn-xl" id="extract"><LockKeyholeOpen/></button>
      </div>
      <div class="py-6 flex flex-col gap-6 flex-1">
        <textarea class="textarea textarea-info w-full h-136 bg-base-200" id="coverText"></textarea>
        <fieldset class="fieldset">
          <legend class="fieldset-legend" id="privateKeyTitle"></legend>
          <input type="file" class="file-input file-input-warning" id="privateKey" aria-labelledby="privateKeyTitle"/>
        </fieldset>
      </div>
    </div>
    <progress class="progress progress-primary invisible" value="0" max="100" id="progress"></progress>
  </div>
  <div class="flex flex-row gap-4 items-center mb-10 mx-6 lg:mx-14 2xl:mx-42 px-4">
      <textarea class="textarea textarea-info w-full h-26 bg-base-200" id="prompt"></textarea>
      <div class="flex flex-col">
        <button class="btn btn-ghost" id="up">▲</button>
        <button class="btn btn-ghost" id="down">▼</button>
      </div>
  </div>
  <script>
    import { $,get,post,getLocal,setLocal,moveToEnd,generateKeyPair, unishoxCompress, eccEncryptToUint8Array, eccDecryptToUint8Array, toBinary, toBytes, findSublist, unishoxDecompress,showAlert,magicNum1,magicNum2} from "../assets/commonUtils";
    import { t } from "../assets/i18n";
    // draft：一种牺牲隐写容量提高鲁棒性和隐写效果的方法：部分截取片段直接使用，不尝试映射
    // todo：textarea调整为支持富文本之类的能控制文本样式的组件。
    // 不想引入故意的错别字，实现复杂、手动维护还不通用。
    const generateKeyPairMsg = t("generateKeyPairMsg");
    const failMsg = t("failMsg");
    $('generateKeyPair').textContent = t('generateKey');
    $('publicKeyTitle').textContent = t('publicKeyTitle');
    $('privateKeyTitle').textContent = t('privateKeyTitle');
    $('secret').placeholder = t('secretPlaceholder');
    $('coverText').placeholder = t('coverTextPlaceholder');
    $('prompt').placeholder = t('promptPlaceholder');
    $('hide').ariaLabel = t('hide');
    $('extract').ariaLabel = t('extract');
    $('insertionText').textContent = t('insertionText');
    $('stopTip').dataset.tip = t('stopTip');
    $('hide').dataset.tip = t('hideTip');
    $('insertion').checked = getLocal("insertion", true);
    $('insertion').addEventListener("change", () => setLocal("insertion", $('insertion').checked));
    let prompts = getLocal("prompts", []), promptIndex = prompts.length - 1;
    if (promptIndex >= 0) $('prompt').value = prompts[promptIndex];
    $('up').onclick = () => {
      if (promptIndex > 0) $('prompt').value = prompts[--promptIndex];
    };
    $('down').onclick = () => {
      if (promptIndex < prompts.length - 1) $('prompt').value = prompts[++promptIndex];
    };
    $('generateKeyPair').onclick = async () => {
      await generateKeyPair();
      showAlert(generateKeyPairMsg);
    };
    async function getParity(str) {//直接%2无法利用哈希值的全部位，会破坏哈希函数的均匀性，必须使用奇偶校验或者可扩展输出函数 (XOF)
        const hashBuffer = await crypto.subtle.digest('SHA-512', new TextEncoder().encode(str));
        const hashArray = new Uint8Array(hashBuffer);
        let finalByte = hashArray.reduce((acc, byte) => acc ^ byte, 0);
        let popcount = 0;
        for (;finalByte > 0;) {
            finalByte &= (finalByte - 1);
            popcount++;
        }
        return popcount%2;
    }
    function getWeight(code) {
      if (code === 32 ||code === 44 ||code === 46 || (code >= 65 && code <= 90) ||(code >= 97 && code <= 122) )//必须保留的字符（中断将严重破坏语义）：普通空格、英文逗号、英文句号、大写字母、小写字母
        return 1;
      if (code === 65292 || code === 12290 || code === 8221 || code === 30340)//尽量保留的字符（哪怕不中断也还有可能续写）：中文逗号，中文句号，中文右双引号、的
        return 2;
      return 3;
    }
    async function tokenize(str) {
        return (await post('/tokenize',{content:str})).tokens;
    }
    async function detokenize(tokens) {//不返回bytes
        return (await post('/detokenize',{tokens})).content;
    }
    async function applyTemplate(messages) {
        return (await post('/apply-template', { messages })).prompt;
    }
    let eosToken;
    if (window.location.hostname === "127.0.0.1") {
        const props=await get("/props");
        eosToken=props.eos_token;
    }
    async function completion(prompt, tailNpredict = 0) {
      let body = {
        prompt: prompt, //支持输入多个prompt
        response_fields: tailNpredict ? ["content", "stopping_word", "stop_type"] : ["completion_probabilities","tokens"],
      };
      if (tailNpredict) {
        body["n_predict"] = tailNpredict;
      } else {
        body["n_predict"] = 1;//预测的最大token数，如果最后一个标记是部分多字节字符，则可能会略微超过设置的限制。
        body["top_k"] = 120;
        body["n_probs"] = 120;
        body["post_sampling_probs"] = true;//返回应用采样链后token的概率，不开启时返回的logprob是和采样无关的，logitBias也不会生效
        body["return_tokens"] = true;//概率非常小的情况下，不会返回采样列表completion_probabilities
      }
      const json = await post("/completion",body);
      if (tailNpredict) {
        if (json.stop_type === "eos") return json.content;
        if (tailNpredict < 256) return await completion(prompt, tailNpredict * 2);
        return json.content;
      }
      const probs = json.completion_probabilities;
      if (!probs) return [{id: json.tokens[0],token: ""},];
      return probs[0].top_probs;
    }
    let targetBits, currentPrompt, done, allowInsertion;
    async function dfs(bitPos, accChars, accScore, pending) {
      $('progress').value = bitPos / targetBits.length * 100;
      const candidates = await completion(currentPrompt);
      for (let j = 0; j < candidates.length; j++) {
        if (done) return;
        if (candidates[j].bytes && candidates[j].bytes.length > 0) {
          const byteDecoded = new TextDecoder().decode(new Uint8Array(candidates[j].bytes));
          if (byteDecoded.includes("\uFFFD")) continue;
        }
        let tokenText, needsDeeperDecode;
        if (pending > 0) {
          const combined = [...currentPrompt.slice(-pending), candidates[j].id];
          tokenText = await detokenize(combined);
          if (tokenText.includes("\uFFFD")) continue;
          needsDeeperDecode = tokenText.includes("\uFFFD");
        } else {
          tokenText = candidates[j].token;
          needsDeeperDecode = tokenText === "" || (tokenText.includes("\uFFFD") && tokenText[0] !== "\uFFFD");
        }
        if (needsDeeperDecode) {
          if (pending === 0) {
            const extra = await detokenize([candidates[j].id]);
            if (extra.includes(eosToken) || extra.includes("<|endoftext|>")) continue;//禁止中断时会输出大量无意义token，应手动处理使其自动回溯
            if (extra.includes("\uFFFD")) continue;
          }
          currentPrompt.push(candidates[j].id);
          await dfs(bitPos, accChars, accScore, pending + 1);
          currentPrompt.pop();
          continue;
        }
        let groupChars = accChars,
          groupScore = accScore,
          bitsMatched = 0;
        const codePoints = [...tokenText];
        for (let k = 0; ; k++) {
          if (k >= codePoints.length) {
            currentPrompt.push(candidates[j].id);
            $('coverText').value += tokenText;
            await dfs(bitPos + bitsMatched, groupChars, groupScore, 0);
            if (done) return; //在这里return避免逐层回溯，导致文本框内容变化
            currentPrompt.pop();
            $('coverText').value = $('coverText').value.slice(0, -tokenText.length);
            break;
          }
          groupChars += codePoints[k];
          groupScore += getWeight(codePoints[k].codePointAt(0));
          if (groupScore >= 3) {
            if ((await getParity(groupChars)) !== targetBits[bitPos + bitsMatched]) break;
            bitsMatched++;
            groupChars = "";
            groupScore = 0; //使用-=3会提高token的平均映射次数，长短token的不平衡会更加明显
            if (bitPos + bitsMatched === targetBits.length) {
              done = true;
              if (allowInsertion) {
                currentPrompt.push(candidates[j].id);
                $('coverText').value += tokenText;
                $('coverText').value += await completion(currentPrompt, 1);
              } else $('coverText').value += codePoints.slice(0, k + 1).join('');
              return;
            }
          }
        }
      }
    }
    async function encrypt(prompt, plainText) {
      if (!$('progress').classList.contains("invisible")) {
        done = true;
        return;
      }
      if (!plainText) {
        $('secret').focus();
        return;
      }
      if (!prompt) {
        $('prompt').focus();
        return;
      }
      moveToEnd(prompts,prompt,100);
      setLocal('prompts',prompts);
      promptIndex = prompts.length - 1;
      let [data, useUnishox] = await unishoxCompress(plainText);
      const key = await ($('publicKey').files?.[0]?.text() ?? null);
      if (key) data = await eccEncryptToUint8Array(data, JSON.parse(key));
      targetBits = toBinary(data); //targetBits=[useUnishox,...toBinary(data)];//处理为二进制序列，在映射时粒度更细，但建议每次只映射1位，减少映射失败率。
      allowInsertion = $('insertion').checked;
      const trimIdx = targetBits.lastIndexOf(useUnishox || key ? 0 : 1) + 1;
      targetBits = targetBits.slice(0, targetBits.length - trimIdx <= 7 ? trimIdx : targetBits.length - 7);
      if (allowInsertion) targetBits = [...magicNum1, ...targetBits, ...magicNum2];
      let finalPrompt;
      const messages = [];
      //if (systemPrompt) messages.push({ role: "system", content: systemPrompt });
      messages.push({ role: "user", content: prompt });
      finalPrompt = await applyTemplate(messages);
      currentPrompt = await tokenize(finalPrompt);
      $('coverText').value = "";
      done = false;
      $('progress').value="0";
      $('progress').classList.remove("invisible");
      $('hide').classList.add("tooltip");
      await dfs(0, "", 0, 0);
      $('hide').classList.remove("tooltip");
      $('progress').classList.add("invisible");
      if (!done) showAlert(failMsg);
    }
    async function extract(coverText) {
      if (!coverText) {
        $('coverText').focus();
        return;
      }
      let extractedBits = [], groupChars = "", groupScore = 0;
      for (const char of coverText) {
        groupChars += char;
        groupScore += getWeight(char.codePointAt(0));
        if (groupScore >= 3) {
          extractedBits.push((await getParity(groupChars)));
          groupChars = "";
          groupScore = 0;
        }
      }
      let index1 = findSublist(extractedBits, magicNum1);
      let index2 = findSublist(extractedBits, magicNum2);
      if (index1 !== -1 && index2 !== -1 && index2 > index1 + magicNum1.length)
          extractedBits = extractedBits.slice(index1 + magicNum1.length, index2);
      // let useUnishox=extractedBits[0];extractedBits=extractedBits.slice(1);
      const key = await ($('privateKey').files?.[0]?.text() ?? null);
      if (key) extractedBits = await eccDecryptToUint8Array(toBytes([...extractedBits, ...Array((8 - extractedBits.length % 8) % 8).fill(1)]), JSON.parse(key));
      $('secret').value = await unishoxDecompress(extractedBits);
    }
    $('hide').onclick = async () => {
      await encrypt($('prompt').value, $('secret').value);
    };
    $('extract').onclick = async () => {
      await extract($('coverText').value);
    };
  </script>
</Layout>